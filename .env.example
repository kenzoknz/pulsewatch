# ──────────────────────────────────────────────────────────────
# PulseWatch – Docker Compose environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (already in .gitignore).
# ──────────────────────────────────────────────────────────────

# SQL Server SA password (min 8 chars, upper+lower+digit+symbol)
DB_SA_PASSWORD=PulseWatch_DB_P@ss2024!

# JWT signing key – MUST be changed in production (min 32 chars)
JWT_KEY=PulseWatch_Super_Secret_Key_Change_This_In_Production_Min_32_Characters!

# SMTP settings (optional – leave blank to run in log/mock mode)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=alerts@pulsewatch.com
